<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".view.AlterarClienteActivity">

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:text="Alterar dados cliente"
        android:textSize="30dp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/editTextNomeUser"
        android:layout_width="295dp"
        android:layout_height="47dp"
        android:layout_marginTop="108dp"
        android:background="@drawable/edit_text_custom"
        android:ems="10"
        android:hint="Digite seu nome:"
        android:inputType="text"
        android:minWidth="300px"
        android:padding="20px"
        android:textColorHint="@color/black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.525"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView" />

    <EditText
        android:id="@+id/editTextEmailUser"
        android:layout_width="295dp"
        android:layout_height="47dp"
        android:layout_marginTop="52dp"
        android:background="@drawable/edit_text_custom"
        android:ems="10"
        android:hint="Informe seu email:"
        android:inputType="textEmailAddress"
        android:minWidth="300px"
        android:padding="20px"
        android:textColorHint="@color/black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editTextNomeUser" />

    <EditText
        android:id="@+id/editTextTelUser"
        android:layout_width="295dp"
        android:layout_height="47dp"
        android:layout_marginTop="48dp"
        android:background="@drawable/edit_text_custom"
        android:ems="10"
        android:hint="Informe seu telefone:"
        android:inputType="number"
        android:minWidth="300px"
        android:padding="20px"
        android:textColorHint="@color/black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editTextEmailUser" />

    <Button
        android:id="@+id/button"
        android:layout_width="150dp"
        android:layout_height="50dp"
        android:layout_marginTop="68dp"

        android:backgroundTint="#10AF15"
        android:text="Salvar alterações"
        android:textSize="13dp"
        app:cornerRadius="5dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.172"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editTextTelUser" />

    <Button
        android:id="@+id/button2"
        android:layout_width="150dp"
        android:layout_height="50dp"
        android:layout_marginTop="68dp"
        android:backgroundTint="#EF3535"
        android:text="Cancelar"
        app:cornerRadius="5dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.378"
        app:layout_constraintStart_toEndOf="@id/button"
        app:layout_constraintTop_toBottomOf="@+id/editTextTelUser" />
</androidx.constraintlayout.widget.ConstraintLayout>
