<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".view.ApagarActivity">


    <LinearLayout
        android:id="@+id/layout"
        android:layout_width="412dp"
        android:layout_height="337dp"
        android:layout_marginTop="4dp"
        android:background="#376CB1"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        tools:ignore="MissingConstraints">


        <TextView
            android:id="@+id/apagarCliente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="80dp"
            android:text="Apagar cliente"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            />


        <EditText
            android:id="@+id/emailClienteApagar"
            android:layout_width="295dp"
            android:layout_height="47dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:background="@drawable/edit_text_custom"
            android:hint="Informe o Email:"
            android:padding="10dp"
            android:textColorHint="#4B4B4B" />

    </LinearLayout>

    <Button
            android:id="@+id/button"
            android:layout_width="120dp"
            android:layout_height="50dp"
            android:backgroundTint="#EF3535"
            android:text="Apagar"
            app:cornerRadius="5dp"
            tools:layout_editor_absoluteX="63dp"
            tools:layout_editor_absoluteY="243dp"
        tools:ignore="MissingConstraints" />

        <Button
        android:id="@+id/button2"
        android:layout_width="120dp"
        android:layout_height="50dp"
        android:backgroundTint="#19998D"
        android:text="Voltar"
        app:cornerRadius="5dp"
        tools:layout_editor_absoluteX="233dp"
        tools:layout_editor_absoluteY="243dp"
            tools:ignore="MissingConstraints" />
    </androidx.constraintlayout.widget.ConstraintLayout>

